# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=manifest_prod
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT — generate a strong random secret:  openssl rand -hex 32
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# First-run super admin (only used when DB has no admins)
SEED_ADMIN_NAME=Your Name
SEED_ADMIN_EMAIL=you@example.com
SEED_ADMIN_PASSWORD=change-this-strong-password

# CORS — comma-separated frontend origins
# Add your Vercel URL and custom domain once known
CORS_ORIGINS=https://your-app.vercel.app,https://yourdomain.com
